{
  "info": {
    "name": "InfiniteChat Agent - Memory Agent 完整接口测试",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:10010/api"
    },
    {
      "key": "memoryId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 ReAct 对话 - 积累短期 Redis 记忆",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/agent/chat",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "agent",
            "chat"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": 1001,\n  \"sessionId\": 93001,\n  \"prompt\": \"我正在开发 InfiniteChat-Agent 项目，已经完成 ReAct、Adaptive RAG 和 Memory Agent。\"\n}"
        }
      }
    },
    {
      "name": "02 ReAct 对话 - 继续积累短期记忆",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/agent/chat",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "agent",
            "chat"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": 1001,\n  \"sessionId\": 93001,\n  \"prompt\": \"下一步我想完善工具治理和多模态报错截图分析。\"\n}"
        }
      }
    },
    {
      "name": "03 手动生成 Session Summary",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/memory/session/summarize",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "memory",
            "session",
            "summarize"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": 1001,\n  \"sessionId\": 93001\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Session Summary 已生成', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.summary).to.be.a('string').that.is.not.empty;",
              "  pm.expect(json.turnCount).to.be.a('number');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "04 查询 Session Summary",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/memory/session/summary?userId=1001&sessionId=93001",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "memory",
            "session",
            "summary"
          ],
          "query": [
            {
              "key": "userId",
              "value": "1001"
            },
            {
              "key": "sessionId",
              "value": "93001"
            }
          ]
        }
      }
    },
    {
      "name": "05 写入长期记忆 - TECH_STACK",
      "request": {
        "method": "POST",
        "header": [
