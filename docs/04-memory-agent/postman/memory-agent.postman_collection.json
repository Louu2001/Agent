        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": 1001,\n  \"sessionId\": 93001,\n  \"memoryType\": \"TECH_STACK\",\n  \"content\": \"用户的 Agent 项目核心技术栈是 Spring Boot 3、Java 17、LangChain4j、Redis、MySQL、Qwen、Prometheus 和 Grafana。\",\n  \"summary\": \"Agent 项目技术栈：Spring Boot 3、Java 17、LangChain4j、Redis、MySQL、Qwen、Prometheus、Grafana。\",\n  \"confidence\": 0.95,\n  \"source\": \"manual\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('长期记忆写入成功', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.memoryId).to.be.a('string').that.is.not.empty;",
              "  pm.collectionVariables.set('memoryId', json.memoryId);",
              "});"
            ]
          }
        }
      ]
    },
